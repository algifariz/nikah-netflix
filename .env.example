# =============================================
# NIKAH NETFLIX - Environment Variables
# Copy this to .env and fill in your values
# For Vercel: Add these in Project Settings > Environment Variables
# =============================================

# Supabase - Get from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site URL (for OG images & social sharing) - Set your production domain here
# Example: https://nikah-netflix.vercel.app or your custom domain
NEXT_PUBLIC_URL=https://your-domain.vercel.app

# Admin Login
# Create admin user in Supabase Dashboard > Authentication > Users
# Then use those credentials to log in at /admin/login
